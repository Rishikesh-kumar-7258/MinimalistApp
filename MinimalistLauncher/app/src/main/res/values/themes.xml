<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        NoActionBar keeps the window chrome out of the way.
        Compose handles all UI including status/nav bar via enableEdgeToEdge().
    -->
    <style name="Theme.MinimalistLauncher" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
